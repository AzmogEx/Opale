# --- Opale — variables d'environnement (exemple) ---
# Copier en `.env` et adapter. Ne jamais committer `.env` (secrets hors code, §16).

# ── Serveur ───────────────────────────────────────────────────────────────────
OPALE_HTTP_ADDR=:8080
OPALE_ENV=dev                       # dev | prod
OPALE_LOG_LEVEL=info                # debug | info | warn | error

# ── Base de données PostgreSQL ────────────────────────────────────────────────
OPALE_DB_HOST=localhost
OPALE_DB_PORT=5432                  # dev local : 5433 (cf. docker-compose)
OPALE_DB_USER=opale
OPALE_DB_PASSWORD=changeme-en-prod
OPALE_DB_NAME=opale
OPALE_DB_SSLMODE=disable            # disable en local, require en prod
# Alternative : URL complète (prioritaire si renseignée)
# OPALE_DATABASE_URL=postgres://opale:changeme@localhost:5432/opale?sslmode=disable

# ── Sécurité ──────────────────────────────────────────────────────────────────
OPALE_SESSION_TTL=720h              # durée de validité d'une session (Go duration)

# ── Coffre-fort (EF-064) — chiffrement AES-256-GCM des documents ─────────────
# 64 caractères hexadécimaux (32 octets). Générer : openssl rand -hex 32
# ⚠️ À SAUVEGARDER précieusement : clé perdue = documents illisibles.
OPALE_VAULT_KEY=

# ── IA en cascade (P5) — chaque niveau est optionnel ─────────────────────────
# N2 : serveur Ollama du homelab (RTX 5080). Vide = niveau désactivé.
OPALE_OLLAMA_URL=                   # ex. http://192.168.1.50:11434
OPALE_OLLAMA_MODEL=llama3.1:8b
# N3 : cloud Claude Fable 5 — ne reçoit QUE des données anonymisées (EIA-031/033).
OPALE_ANTHROPIC_API_KEY=
OPALE_CLOUD_AI=on                   # off = interdit le cloud même avec une clé

# ── Synchro bancaire GoCardless (EF-071) — optionnel ─────────────────────────
# Compte gratuit : https://bankaccountdata.gocardless.com
OPALE_GC_SECRET_ID=
OPALE_GC_SECRET_KEY=
# OPALE_GC_BASE_URL=                # surcharge pour les tests (mock)

# ── CORS (future app web) ─────────────────────────────────────────────────────
# Origines autorisées, séparées par des virgules. Vide = désactivé.
# OPALE_CORS_ORIGINS=https://opale.mondomaine.fr
